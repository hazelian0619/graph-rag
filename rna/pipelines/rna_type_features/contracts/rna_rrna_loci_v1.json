{
  "name": "rna_rrna_loci_v1",
  "description": "Human rRNA loci table extracted from RNAcentral external coordinate annotations",
  "required_columns": [
    "rrna_locus_id",
    "rna_id",
    "urs_id",
    "taxon_id",
    "rrna_type",
    "seq_accession",
    "locus_start",
    "locus_end",
    "strand",
    "source_db",
    "external_id",
    "gene_symbol",
    "source",
    "source_version",
    "fetch_date"
  ],
  "rules": [
    {"id": "rrna_locus_id_non_empty", "type": "non_empty_rate", "column": "rrna_locus_id", "min_rate": 1.0},
    {"id": "rrna_locus_id_unique", "type": "unique", "column": "rrna_locus_id"},
    {"id": "rna_id_non_empty", "type": "non_empty_rate", "column": "rna_id", "min_rate": 1.0},
    {"id": "rna_id_format", "type": "regex_rate", "column": "rna_id", "pattern": "^URS[0-9A-Z]+_9606$", "min_rate": 1.0},
    {"id": "urs_id_format", "type": "regex_rate", "column": "urs_id", "pattern": "^URS[0-9A-Z]+_9606$", "min_rate": 1.0},
    {"id": "taxon_human", "type": "equals_value_rate", "column": "taxon_id", "value": "9606", "min_rate": 1.0},
    {"id": "rrna_type_non_empty", "type": "non_empty_rate", "column": "rrna_type", "min_rate": 1.0},
    {"id": "seq_accession_non_empty", "type": "non_empty_rate", "column": "seq_accession", "min_rate": 1.0},
    {"id": "locus_start_numeric", "type": "regex_rate", "column": "locus_start", "pattern": "^[0-9]+$", "min_rate": 1.0},
    {"id": "locus_end_numeric", "type": "regex_rate", "column": "locus_end", "pattern": "^[0-9]+$", "min_rate": 1.0},
    {"id": "strand_enum", "type": "regex_rate", "column": "strand", "pattern": "^[+\\-.]$", "min_rate": 1.0},
    {"id": "source_db_non_empty", "type": "non_empty_rate", "column": "source_db", "min_rate": 1.0},
    {"id": "external_id_non_empty", "type": "non_empty_rate", "column": "external_id", "min_rate": 1.0},
    {"id": "source_non_empty", "type": "non_empty_rate", "column": "source", "min_rate": 1.0},
    {"id": "source_version_non_empty", "type": "non_empty_rate", "column": "source_version", "min_rate": 1.0},
    {"id": "fetch_date_iso", "type": "regex_rate", "column": "fetch_date", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "min_rate": 1.0}
  ]
}
