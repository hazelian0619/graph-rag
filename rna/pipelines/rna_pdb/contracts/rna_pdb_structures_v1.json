{
  "name": "rna_pdb_structures_v1",
  "description": "RNA to PDB structure mapping with RCSB metadata",
  "required_columns": [
    "rna_id",
    "rna_type",
    "urs_id",
    "pdb_id",
    "pdb_entity_id",
    "mapping_strategy",
    "experimental_method",
    "resolution",
    "release_date",
    "source",
    "source_version",
    "fetch_date"
  ],
  "rules": [
    {
      "id": "rna_id_non_empty",
      "type": "non_empty_rate",
      "column": "rna_id",
      "min_rate": 1.0
    },
    {
      "id": "urs_id_non_empty",
      "type": "non_empty_rate",
      "column": "urs_id",
      "min_rate": 1.0
    },
    {
      "id": "pdb_id_non_empty",
      "type": "non_empty_rate",
      "column": "pdb_id",
      "min_rate": 1.0
    },
    {
      "id": "pdb_id_format",
      "type": "regex_rate",
      "column": "pdb_id",
      "pattern": "^[0-9A-Z]{4}$",
      "min_rate": 1.0
    },
    {
      "id": "source_non_empty",
      "type": "non_empty_rate",
      "column": "source",
      "min_rate": 1.0
    },
    {
      "id": "source_allowed",
      "type": "allowed_values_rate",
      "column": "source",
      "allowed": [
        "RCSB_DATA_API"
      ],
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_non_empty",
      "type": "non_empty_rate",
      "column": "fetch_date",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_format",
      "type": "regex_rate",
      "column": "fetch_date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "min_rate": 1.0
    }
  ]
}
