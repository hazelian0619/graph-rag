{
  "name": "protein_isoform_map_v1",
  "description": "Canonical-to-isoform mapping table (canonical ↔ isoform) derived from protein_isoform_v1",
  "required_columns": [
    "map_id",
    "canonical_uniprot_id",
    "isoform_uniprot_id",
    "boundary_class",
    "relation_type",
    "mapping_scope",
    "sequence_status_class",
    "source",
    "source_version",
    "fetch_date"
  ],
  "rules": [
    {
      "id": "map_id_non_empty",
      "type": "non_empty_rate",
      "column": "map_id",
      "min_rate": 1.0
    },
    {
      "id": "map_id_unique",
      "type": "unique",
      "column": "map_id"
    },
    {
      "id": "canonical_uniprot_id_format",
      "type": "regex_rate",
      "column": "canonical_uniprot_id",
      "pattern": "^[A-Z0-9]{6,10}$",
      "min_rate": 1.0
    },
    {
      "id": "isoform_uniprot_id_format",
      "type": "regex_rate",
      "column": "isoform_uniprot_id",
      "pattern": "^[A-Z0-9]{6,10}-[0-9]+$",
      "min_rate": 1.0
    },
    {
      "id": "boundary_class_allowed",
      "type": "allowed_values_rate",
      "column": "boundary_class",
      "allowed": ["canonical", "isoform"],
      "min_rate": 1.0
    },
    {
      "id": "mapping_scope_allowed",
      "type": "allowed_values_rate",
      "column": "mapping_scope",
      "allowed": ["self_accession", "cross_accession"],
      "min_rate": 1.0
    },
    {
      "id": "relation_type_allowed",
      "type": "allowed_values_rate",
      "column": "relation_type",
      "allowed": [
        "canonical_displayed",
        "canonical_isoform",
        "cross_accession_displayed",
        "cross_accession_isoform"
      ],
      "min_rate": 1.0
    },
    {
      "id": "sequence_status_class_allowed",
      "type": "allowed_values_rate",
      "column": "sequence_status_class",
      "allowed": ["displayed", "variant_vsp", "missing", "other"],
      "min_rate": 1.0
    },
    {
      "id": "source_non_empty",
      "type": "non_empty_rate",
      "column": "source",
      "min_rate": 1.0
    },
    {
      "id": "source_version_non_empty",
      "type": "non_empty_rate",
      "column": "source_version",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_non_empty",
      "type": "non_empty_rate",
      "column": "fetch_date",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_format",
      "type": "regex_rate",
      "column": "fetch_date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "min_rate": 1.0
    }
  ]
}
