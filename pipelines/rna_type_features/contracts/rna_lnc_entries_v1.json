{
  "name": "rna_lnc_entries_v1",
  "description": "Human lncRNA transcript entries derived from Ensembl GTF with RNAcentral mapping",
  "required_columns": [
    "rna_id",
    "urs_id",
    "taxon_id",
    "ensembl_transcript_id",
    "ensembl_gene_id",
    "gene_symbol",
    "rna_name",
    "chrom",
    "locus_start",
    "locus_end",
    "strand",
    "biotype",
    "mapping_status",
    "source",
    "source_version",
    "fetch_date"
  ],
  "rules": [
    {"id": "rna_id_non_empty", "type": "non_empty_rate", "column": "rna_id", "min_rate": 1.0},
    {"id": "rna_id_format", "type": "regex_rate", "column": "rna_id", "pattern": "^(URS[0-9A-Z]+_9606|ENST\\d+_9606)$", "min_rate": 1.0},
    {"id": "taxon_human", "type": "equals_value_rate", "column": "taxon_id", "value": "9606", "min_rate": 1.0},
    {"id": "ensembl_transcript_non_empty", "type": "non_empty_rate", "column": "ensembl_transcript_id", "min_rate": 1.0},
    {"id": "ensembl_transcript_format", "type": "regex_rate", "column": "ensembl_transcript_id", "pattern": "^ENST\\d+(\\.\\d+)?$", "min_rate": 1.0},
    {"id": "ensembl_gene_format_or_empty", "type": "regex_rate", "column": "ensembl_gene_id", "pattern": "^(|ENSG\\d+(\\.\\d+)?)$", "min_rate": 1.0},
    {"id": "strand_enum", "type": "regex_rate", "column": "strand", "pattern": "^[+-]$", "min_rate": 1.0},
    {"id": "locus_start_numeric", "type": "regex_rate", "column": "locus_start", "pattern": "^[0-9]+$", "min_rate": 1.0},
    {"id": "locus_end_numeric", "type": "regex_rate", "column": "locus_end", "pattern": "^[0-9]+$", "min_rate": 1.0},
    {"id": "biotype_is_lnc", "type": "regex_rate", "column": "biotype", "pattern": "^lncRNA$", "min_rate": 1.0},
    {"id": "mapping_status_enum", "type": "regex_rate", "column": "mapping_status", "pattern": "^(mapped_enst_version|mapped_enst_base|fallback_enst)$", "min_rate": 1.0},
    {"id": "urs_id_format_or_empty", "type": "regex_rate", "column": "urs_id", "pattern": "^(|URS[0-9A-Z]+_9606)$", "min_rate": 1.0},
    {"id": "source_non_empty", "type": "non_empty_rate", "column": "source", "min_rate": 1.0},
    {"id": "source_version_non_empty", "type": "non_empty_rate", "column": "source_version", "min_rate": 1.0},
    {"id": "fetch_date_iso", "type": "regex_rate", "column": "fetch_date", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "min_rate": 1.0},
    {"id": "ensembl_transcript_unique", "type": "unique", "column": "ensembl_transcript_id"}
  ]
}
