{
  "name": "rpi_site_context_v2",
  "description": "RPI method + binding site context linked by edge_id",
  "required_columns": [
    "context_id",
    "edge_id",
    "reference",
    "method_type",
    "method_subtype",
    "site_type",
    "chromosome",
    "start",
    "end",
    "strand",
    "transcript_id",
    "gene_id",
    "cell_context",
    "support_count",
    "source",
    "source_version",
    "fetch_date"
  ],
  "rules": [
    {"id": "context_id_non_empty", "type": "non_empty_rate", "column": "context_id", "min_rate": 1.0},
    {"id": "edge_id_non_empty", "type": "non_empty_rate", "column": "edge_id", "min_rate": 1.0},
    {"id": "method_type_non_empty", "type": "non_empty_rate", "column": "method_type", "min_rate": 0.9},
    {"id": "method_type_allowed", "type": "allowed_values_rate", "column": "method_type", "allowed": ["CLIP", "RIP", "CHIRP", "RAP", "PARIS", "OTHER"], "min_rate": 1.0},
    {"id": "site_type_allowed", "type": "allowed_values_rate", "column": "site_type", "allowed": ["genomic", "transcript", "unknown"], "min_rate": 1.0},
    {"id": "start_numeric_or_empty", "type": "regex_rate", "column": "start", "pattern": "^(|[0-9]+)$", "min_rate": 1.0},
    {"id": "end_numeric_or_empty", "type": "regex_rate", "column": "end", "pattern": "^(|[0-9]+)$", "min_rate": 1.0},
    {"id": "support_count_numeric_or_empty", "type": "regex_rate", "column": "support_count", "pattern": "^(|-?[0-9]+(\\.[0-9]+)?)$", "min_rate": 1.0},
    {"id": "source_non_empty", "type": "non_empty_rate", "column": "source", "min_rate": 1.0},
    {"id": "source_version_non_empty", "type": "non_empty_rate", "column": "source_version", "min_rate": 1.0},
    {"id": "fetch_date_iso", "type": "regex_rate", "column": "fetch_date", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "min_rate": 1.0}
  ]
}
