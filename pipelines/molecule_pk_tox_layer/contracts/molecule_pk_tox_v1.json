{
  "name": "molecule_pk_tox_v1",
  "description": "Small-molecule PK/Tox layer anchored on molecule_xref_core_v2 (DrugBank extension + optional public tox sources)",
  "required_columns": [
    "inchikey",
    "drugbank_id",
    "pubchem_cid",
    "bioavailability",
    "bioavailability_evidence",
    "bioavailability_source",
    "clearance",
    "clearance_evidence",
    "clearance_source",
    "half_life",
    "half_life_evidence",
    "half_life_source",
    "volume_of_distribution",
    "volume_of_distribution_evidence",
    "volume_of_distribution_source",
    "ld50",
    "ld50_evidence",
    "ld50_source",
    "mutagenicity",
    "mutagenicity_evidence",
    "mutagenicity_source",
    "fetch_date",
    "source_version"
  ],
  "rules": [
    {
      "id": "inchikey_non_empty",
      "type": "non_empty_rate",
      "column": "inchikey",
      "min_rate": 1.0
    },
    {
      "id": "inchikey_format",
      "type": "regex_rate",
      "column": "inchikey",
      "pattern": "^[A-Z]{14}-[A-Z]{10}-[A-Z]$",
      "min_rate": 1.0
    },
    {
      "id": "inchikey_unique",
      "type": "unique",
      "column": "inchikey"
    },
    {
      "id": "bioavailability_evidence_allowed",
      "type": "allowed_values_rate",
      "column": "bioavailability_evidence",
      "allowed": ["structured/high", "text_mined/medium", "inferred/low", "none"],
      "min_rate": 1.0
    },
    {
      "id": "clearance_evidence_allowed",
      "type": "allowed_values_rate",
      "column": "clearance_evidence",
      "allowed": ["structured/high", "text_mined/medium", "inferred/low", "none"],
      "min_rate": 1.0
    },
    {
      "id": "half_life_evidence_allowed",
      "type": "allowed_values_rate",
      "column": "half_life_evidence",
      "allowed": ["structured/high", "text_mined/medium", "inferred/low", "none"],
      "min_rate": 1.0
    },
    {
      "id": "volume_of_distribution_evidence_allowed",
      "type": "allowed_values_rate",
      "column": "volume_of_distribution_evidence",
      "allowed": ["structured/high", "text_mined/medium", "inferred/low", "none"],
      "min_rate": 1.0
    },
    {
      "id": "ld50_evidence_allowed",
      "type": "allowed_values_rate",
      "column": "ld50_evidence",
      "allowed": ["structured/high", "text_mined/medium", "inferred/low", "none"],
      "min_rate": 1.0
    },
    {
      "id": "mutagenicity_evidence_allowed",
      "type": "allowed_values_rate",
      "column": "mutagenicity_evidence",
      "allowed": ["structured/high", "text_mined/medium", "inferred/low", "none"],
      "min_rate": 1.0
    },
    {
      "id": "bioavailability_source_non_empty",
      "type": "non_empty_rate",
      "column": "bioavailability_source",
      "min_rate": 1.0
    },
    {
      "id": "clearance_source_non_empty",
      "type": "non_empty_rate",
      "column": "clearance_source",
      "min_rate": 1.0
    },
    {
      "id": "half_life_source_non_empty",
      "type": "non_empty_rate",
      "column": "half_life_source",
      "min_rate": 1.0
    },
    {
      "id": "volume_of_distribution_source_non_empty",
      "type": "non_empty_rate",
      "column": "volume_of_distribution_source",
      "min_rate": 1.0
    },
    {
      "id": "ld50_source_non_empty",
      "type": "non_empty_rate",
      "column": "ld50_source",
      "min_rate": 1.0
    },
    {
      "id": "mutagenicity_source_non_empty",
      "type": "non_empty_rate",
      "column": "mutagenicity_source",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_format",
      "type": "regex_rate",
      "column": "fetch_date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "min_rate": 1.0
    },
    {
      "id": "source_version_non_empty",
      "type": "non_empty_rate",
      "column": "source_version",
      "min_rate": 1.0
    }
  ]
}
