{
  "name": "protein_physchem_extended_v1",
  "description": "Extended physicochemical properties for proteins, additive to protein_physchem_v1 core",
  "required_columns": [
    "uniprot_id",
    "sequence_len",
    "mass_recalc",
    "isoelectric_point",
    "gravy",
    "aromaticity",
    "instability_index",
    "extinction_coefficient",
    "extinction_coefficient_reduced",
    "aliphatic_index",
    "source",
    "source_version",
    "fetch_date"
  ],
  "rules": [
    {
      "id": "uniprot_id_non_empty",
      "type": "non_empty_rate",
      "column": "uniprot_id",
      "min_rate": 1.0
    },
    {
      "id": "uniprot_id_unique",
      "type": "unique",
      "column": "uniprot_id"
    },
    {
      "id": "uniprot_id_format",
      "type": "regex_rate",
      "column": "uniprot_id",
      "pattern": "^[A-Z0-9]{6,10}(\\|[A-Z0-9]{6,10})*$",
      "min_rate": 1.0
    },
    {
      "id": "sequence_len_numeric",
      "type": "regex_rate",
      "column": "sequence_len",
      "pattern": "^[0-9]+$",
      "min_rate": 1.0
    },
    {
      "id": "mass_recalc_numeric",
      "type": "regex_rate",
      "column": "mass_recalc",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "min_rate": 1.0
    },
    {
      "id": "isoelectric_point_numeric",
      "type": "regex_rate",
      "column": "isoelectric_point",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "min_rate": 1.0
    },
    {
      "id": "gravy_numeric",
      "type": "regex_rate",
      "column": "gravy",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "min_rate": 1.0
    },
    {
      "id": "aromaticity_numeric",
      "type": "regex_rate",
      "column": "aromaticity",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "min_rate": 1.0
    },
    {
      "id": "instability_index_numeric",
      "type": "regex_rate",
      "column": "instability_index",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "min_rate": 1.0
    },
    {
      "id": "extinction_coefficient_numeric",
      "type": "regex_rate",
      "column": "extinction_coefficient",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "min_rate": 1.0
    },
    {
      "id": "extinction_coefficient_reduced_numeric",
      "type": "regex_rate",
      "column": "extinction_coefficient_reduced",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "min_rate": 1.0
    },
    {
      "id": "aliphatic_index_numeric",
      "type": "regex_rate",
      "column": "aliphatic_index",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "min_rate": 1.0
    },
    {
      "id": "source_non_empty",
      "type": "non_empty_rate",
      "column": "source",
      "min_rate": 1.0
    },
    {
      "id": "source_version_non_empty",
      "type": "non_empty_rate",
      "column": "source_version",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_non_empty",
      "type": "non_empty_rate",
      "column": "fetch_date",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_format",
      "type": "regex_rate",
      "column": "fetch_date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "min_rate": 1.0
    }
  ]
}
