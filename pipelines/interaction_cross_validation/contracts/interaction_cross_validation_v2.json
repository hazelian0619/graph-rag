{
  "name": "interaction_cross_validation_v2",
  "description": "Cross-library consistency and conflict flags for PPI/PSI/RPI interactions",
  "required_columns": [
    "record_id",
    "interaction_type",
    "edge_id",
    "entity_pair_key",
    "consistent_across_n",
    "source_list",
    "evidence_count",
    "distinct_methods_n",
    "reference_count",
    "predicate_set",
    "direction_set",
    "conflict_flag",
    "conflict_reason",
    "source_version_list",
    "fetch_date"
  ],
  "rules": [
    {
      "id": "record_id_non_empty",
      "type": "non_empty_rate",
      "column": "record_id",
      "min_rate": 1.0
    },
    {
      "id": "record_id_unique",
      "type": "unique",
      "column": "record_id"
    },
    {
      "id": "interaction_type_allowed",
      "type": "allowed_values_rate",
      "column": "interaction_type",
      "allowed": ["PPI", "PSI", "RPI"],
      "min_rate": 1.0
    },
    {
      "id": "edge_id_non_empty",
      "type": "non_empty_rate",
      "column": "edge_id",
      "min_rate": 1.0
    },
    {
      "id": "entity_pair_key_non_empty",
      "type": "non_empty_rate",
      "column": "entity_pair_key",
      "min_rate": 1.0
    },
    {
      "id": "consistent_across_n_integer",
      "type": "regex_rate",
      "column": "consistent_across_n",
      "pattern": "^[0-9]+$",
      "min_rate": 1.0
    },
    {
      "id": "source_list_non_empty",
      "type": "non_empty_rate",
      "column": "source_list",
      "min_rate": 1.0
    },
    {
      "id": "evidence_count_integer",
      "type": "regex_rate",
      "column": "evidence_count",
      "pattern": "^[0-9]+$",
      "min_rate": 1.0
    },
    {
      "id": "distinct_methods_n_integer",
      "type": "regex_rate",
      "column": "distinct_methods_n",
      "pattern": "^[0-9]+$",
      "min_rate": 1.0
    },
    {
      "id": "reference_count_integer",
      "type": "regex_rate",
      "column": "reference_count",
      "pattern": "^[0-9]+$",
      "min_rate": 1.0
    },
    {
      "id": "conflict_flag_bool",
      "type": "regex_rate",
      "column": "conflict_flag",
      "pattern": "^(true|false)$",
      "min_rate": 1.0
    },
    {
      "id": "source_version_list_non_empty",
      "type": "non_empty_rate",
      "column": "source_version_list",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_iso",
      "type": "regex_rate",
      "column": "fetch_date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "min_rate": 1.0
    }
  ]
}
