{
  "name": "interaction_aggregate_score_v2",
  "description": "Unified 0-1 aggregate confidence scores for PPI/PSI/RPI interactions",
  "required_columns": [
    "aggregate_id",
    "interaction_type",
    "edge_id",
    "consistent_across_n",
    "evidence_count",
    "distinct_methods_n",
    "numeric_score_max",
    "numeric_score_norm",
    "reference_coverage",
    "context_coverage",
    "conflict_flag",
    "aggregate_score",
    "score_bucket",
    "fetch_date"
  ],
  "rules": [
    {
      "id": "aggregate_id_non_empty",
      "type": "non_empty_rate",
      "column": "aggregate_id",
      "min_rate": 1.0
    },
    {
      "id": "aggregate_id_unique",
      "type": "unique",
      "column": "aggregate_id"
    },
    {
      "id": "interaction_type_allowed",
      "type": "allowed_values_rate",
      "column": "interaction_type",
      "allowed": ["PPI", "PSI", "RPI"],
      "min_rate": 1.0
    },
    {
      "id": "edge_id_non_empty",
      "type": "non_empty_rate",
      "column": "edge_id",
      "min_rate": 1.0
    },
    {
      "id": "edge_id_unique",
      "type": "unique",
      "column": "edge_id"
    },
    {
      "id": "consistent_across_n_integer",
      "type": "regex_rate",
      "column": "consistent_across_n",
      "pattern": "^[0-9]+$",
      "min_rate": 1.0
    },
    {
      "id": "evidence_count_integer",
      "type": "regex_rate",
      "column": "evidence_count",
      "pattern": "^[0-9]+$",
      "min_rate": 1.0
    },
    {
      "id": "distinct_methods_n_integer",
      "type": "regex_rate",
      "column": "distinct_methods_n",
      "pattern": "^[0-9]+$",
      "min_rate": 1.0
    },
    {
      "id": "numeric_score_max_numeric_or_empty",
      "type": "regex_rate",
      "column": "numeric_score_max",
      "pattern": "^(|-?[0-9]+(\\.[0-9]+)?)$",
      "min_rate": 1.0
    },
    {
      "id": "numeric_score_norm_in_0_1",
      "type": "regex_rate",
      "column": "numeric_score_norm",
      "pattern": "^(0(\\.[0-9]+)?|1(\\.0+)?)$",
      "min_rate": 1.0
    },
    {
      "id": "reference_coverage_in_0_1",
      "type": "regex_rate",
      "column": "reference_coverage",
      "pattern": "^(0(\\.[0-9]+)?|1(\\.0+)?)$",
      "min_rate": 1.0
    },
    {
      "id": "context_coverage_in_0_1",
      "type": "regex_rate",
      "column": "context_coverage",
      "pattern": "^(0(\\.[0-9]+)?|1(\\.0+)?)$",
      "min_rate": 1.0
    },
    {
      "id": "conflict_flag_bool",
      "type": "regex_rate",
      "column": "conflict_flag",
      "pattern": "^(true|false)$",
      "min_rate": 1.0
    },
    {
      "id": "aggregate_score_in_0_1",
      "type": "regex_rate",
      "column": "aggregate_score",
      "pattern": "^(0(\\.[0-9]+)?|1(\\.0+)?)$",
      "min_rate": 1.0
    },
    {
      "id": "score_bucket_allowed",
      "type": "allowed_values_rate",
      "column": "score_bucket",
      "allowed": ["high", "medium", "low"],
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_iso",
      "type": "regex_rate",
      "column": "fetch_date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "min_rate": 1.0
    }
  ]
}
