{
  "name": "protein_domains_interpro_v1",
  "description": "Protein domain structured mapping table from InterPro/Pfam API",
  "required_columns": [
    "uniprot_id",
    "interpro_id",
    "pfam_id",
    "entry_name",
    "start",
    "end",
    "source_version",
    "fetch_date"
  ],
  "rules": [
    {
      "id": "uniprot_non_empty",
      "type": "non_empty_rate",
      "column": "uniprot_id",
      "min_rate": 1.0
    },
    {
      "id": "uniprot_format",
      "type": "regex_rate",
      "column": "uniprot_id",
      "pattern": "^[A-Z0-9]+$",
      "min_rate": 1.0
    },
    {
      "id": "interpro_format_or_empty",
      "type": "regex_rate",
      "column": "interpro_id",
      "pattern": "^(|IPR\\d{6})$",
      "min_rate": 1.0
    },
    {
      "id": "pfam_format",
      "type": "regex_rate",
      "column": "pfam_id",
      "pattern": "^PF\\d{5}$",
      "min_rate": 1.0
    },
    {
      "id": "entry_name_non_empty",
      "type": "non_empty_rate",
      "column": "entry_name",
      "min_rate": 1.0
    },
    {
      "id": "start_positive_int",
      "type": "regex_rate",
      "column": "start",
      "pattern": "^[1-9]\\d*$",
      "min_rate": 1.0
    },
    {
      "id": "end_positive_int",
      "type": "regex_rate",
      "column": "end",
      "pattern": "^[1-9]\\d*$",
      "min_rate": 1.0
    },
    {
      "id": "source_version_non_empty",
      "type": "non_empty_rate",
      "column": "source_version",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_iso",
      "type": "regex_rate",
      "column": "fetch_date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "min_rate": 1.0
    }
  ]
}
