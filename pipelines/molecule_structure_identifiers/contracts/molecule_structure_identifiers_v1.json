{
  "name": "molecule_structure_identifiers_v1",
  "description": "Small-molecule structure identifiers layer with ChEMBL-first and PubChem fallback for InChI and canonical SMILES",
  "required_columns": [
    "inchikey",
    "chembl_id",
    "pubchem_cid",
    "inchi",
    "canonical_smiles",
    "inchi_source",
    "canonical_smiles_source",
    "source",
    "source_version",
    "fetch_date"
  ],
  "rules": [
    {
      "id": "inchikey_non_empty",
      "type": "non_empty_rate",
      "column": "inchikey",
      "min_rate": 1.0
    },
    {
      "id": "inchikey_format",
      "type": "regex_rate",
      "column": "inchikey",
      "pattern": "^[A-Z]{14}-[A-Z]{10}-[A-Z]$",
      "min_rate": 1.0
    },
    {
      "id": "inchikey_unique",
      "type": "unique",
      "column": "inchikey"
    },
    {
      "id": "source_non_empty",
      "type": "non_empty_rate",
      "column": "source",
      "min_rate": 1.0
    },
    {
      "id": "source_version_non_empty",
      "type": "non_empty_rate",
      "column": "source_version",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_format",
      "type": "regex_rate",
      "column": "fetch_date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "min_rate": 1.0
    }
  ]
}
