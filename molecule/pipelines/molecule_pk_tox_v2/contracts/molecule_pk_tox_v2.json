{
  "name": "molecule_pk_tox_v2",
  "description": "Small-molecule PK/Tox v2 (DrugBank + ChEMBL multi-source fusion, with normalized numeric/unit fields)",
  "required_columns": [
    "inchikey",
    "chembl_id",
    "drugbank_id",
    "pubchem_cid",
    "bioavailability",
    "bioavailability_pct",
    "bioavailability_evidence",
    "bioavailability_source",
    "clearance",
    "clearance_value",
    "clearance_unit_std",
    "clearance_evidence",
    "clearance_source",
    "half_life",
    "half_life_value",
    "half_life_unit_std",
    "half_life_evidence",
    "half_life_source",
    "volume_of_distribution",
    "volume_distribution_value",
    "volume_distribution_unit_std",
    "volume_of_distribution_evidence",
    "volume_of_distribution_source",
    "ld50",
    "ld50_value",
    "ld50_unit_std",
    "ld50_evidence",
    "ld50_source",
    "mutagenicity",
    "mutagenicity_label_std",
    "mutagenicity_evidence",
    "mutagenicity_source",
    "source",
    "source_version",
    "fetch_date"
  ],
  "rules": [
    {
      "id": "inchikey_non_empty",
      "type": "non_empty_rate",
      "column": "inchikey",
      "min_rate": 1.0
    },
    {
      "id": "inchikey_format",
      "type": "regex_rate",
      "column": "inchikey",
      "pattern": "^[A-Z]{14}-[A-Z]{10}-[A-Z]$",
      "min_rate": 1.0
    },
    {
      "id": "inchikey_unique",
      "type": "unique",
      "column": "inchikey"
    },
    {
      "id": "bioavailability_evidence_allowed",
      "type": "allowed_values_rate",
      "column": "bioavailability_evidence",
      "allowed": ["structured/high", "text_mined/medium", "inferred/low", "none"],
      "min_rate": 1.0
    },
    {
      "id": "clearance_evidence_allowed",
      "type": "allowed_values_rate",
      "column": "clearance_evidence",
      "allowed": ["structured/high", "text_mined/medium", "inferred/low", "none"],
      "min_rate": 1.0
    },
    {
      "id": "half_life_evidence_allowed",
      "type": "allowed_values_rate",
      "column": "half_life_evidence",
      "allowed": ["structured/high", "text_mined/medium", "inferred/low", "none"],
      "min_rate": 1.0
    },
    {
      "id": "volume_of_distribution_evidence_allowed",
      "type": "allowed_values_rate",
      "column": "volume_of_distribution_evidence",
      "allowed": ["structured/high", "text_mined/medium", "inferred/low", "none"],
      "min_rate": 1.0
    },
    {
      "id": "ld50_evidence_allowed",
      "type": "allowed_values_rate",
      "column": "ld50_evidence",
      "allowed": ["structured/high", "text_mined/medium", "inferred/low", "none"],
      "min_rate": 1.0
    },
    {
      "id": "mutagenicity_evidence_allowed",
      "type": "allowed_values_rate",
      "column": "mutagenicity_evidence",
      "allowed": ["structured/high", "text_mined/medium", "inferred/low", "none"],
      "min_rate": 1.0
    },
    {
      "id": "bioavailability_pct_numeric_or_empty",
      "type": "regex_rate",
      "column": "bioavailability_pct",
      "pattern": "^$|^-?\\d+(?:\\.\\d+)?(?:[eE][-+]?\\d+)?$",
      "min_rate": 1.0
    },
    {
      "id": "clearance_value_numeric_or_empty",
      "type": "regex_rate",
      "column": "clearance_value",
      "pattern": "^$|^-?\\d+(?:\\.\\d+)?(?:[eE][-+]?\\d+)?$",
      "min_rate": 1.0
    },
    {
      "id": "clearance_unit_allowed",
      "type": "allowed_values_rate",
      "column": "clearance_unit_std",
      "allowed": ["", "mL/min/kg", "mL/min", "L/h"],
      "min_rate": 1.0
    },
    {
      "id": "half_life_value_numeric_or_empty",
      "type": "regex_rate",
      "column": "half_life_value",
      "pattern": "^$|^-?\\d+(?:\\.\\d+)?(?:[eE][-+]?\\d+)?$",
      "min_rate": 1.0
    },
    {
      "id": "half_life_unit_allowed",
      "type": "allowed_values_rate",
      "column": "half_life_unit_std",
      "allowed": ["", "h"],
      "min_rate": 1.0
    },
    {
      "id": "volume_distribution_value_numeric_or_empty",
      "type": "regex_rate",
      "column": "volume_distribution_value",
      "pattern": "^$|^-?\\d+(?:\\.\\d+)?(?:[eE][-+]?\\d+)?$",
      "min_rate": 1.0
    },
    {
      "id": "volume_distribution_unit_allowed",
      "type": "allowed_values_rate",
      "column": "volume_distribution_unit_std",
      "allowed": ["", "L/kg", "L", "L/1.73m2"],
      "min_rate": 1.0
    },
    {
      "id": "ld50_value_numeric_or_empty",
      "type": "regex_rate",
      "column": "ld50_value",
      "pattern": "^$|^-?\\d+(?:\\.\\d+)?(?:[eE][-+]?\\d+)?$",
      "min_rate": 1.0
    },
    {
      "id": "ld50_unit_allowed",
      "type": "allowed_values_rate",
      "column": "ld50_unit_std",
      "allowed": ["", "mg/kg"],
      "min_rate": 1.0
    },
    {
      "id": "mutagenicity_label_std_allowed",
      "type": "allowed_values_rate",
      "column": "mutagenicity_label_std",
      "allowed": ["positive", "negative", "mixed", "unknown"],
      "min_rate": 1.0
    },
    {
      "id": "source_non_empty",
      "type": "non_empty_rate",
      "column": "source",
      "min_rate": 1.0
    },
    {
      "id": "source_version_non_empty",
      "type": "non_empty_rate",
      "column": "source_version",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_format",
      "type": "regex_rate",
      "column": "fetch_date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "min_rate": 1.0
    }
  ]
}
