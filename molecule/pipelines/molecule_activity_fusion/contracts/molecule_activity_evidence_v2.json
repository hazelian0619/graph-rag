{
  "name": "molecule_activity_evidence_v2",
  "description": "Multi-source molecule-target activity evidence table (ChEMBL + BindingDB + optional PDBbind mapping), unit-normalized to nM",
  "required_columns": [
    "evidence_id",
    "compound_inchikey",
    "compound_chembl_id",
    "target_uniprot_accession",
    "target_chembl_id",
    "source_db",
    "source_record_id",
    "assay_type",
    "standard_type",
    "standard_relation",
    "standard_value",
    "standard_unit",
    "normalized_nM",
    "confidence",
    "confidence_score",
    "reference_doi",
    "reference_pubmed_id",
    "reference_pdb_id",
    "source_raw",
    "source_version",
    "fetch_date"
  ],
  "rules": [
    {
      "id": "evidence_id_non_empty",
      "type": "non_empty_rate",
      "column": "evidence_id",
      "min_rate": 1.0
    },
    {
      "id": "evidence_id_unique",
      "type": "unique",
      "column": "evidence_id"
    },
    {
      "id": "compound_inchikey_format",
      "type": "regex_rate",
      "column": "compound_inchikey",
      "pattern": "^[A-Z]{14}-[A-Z]{10}-[A-Z]$",
      "min_rate": 1.0
    },
    {
      "id": "target_uniprot_non_empty",
      "type": "non_empty_rate",
      "column": "target_uniprot_accession",
      "min_rate": 1.0
    },
    {
      "id": "source_db_allowed",
      "type": "allowed_values_rate",
      "column": "source_db",
      "allowed": ["chembl", "bindingdb", "pdbbind"],
      "min_rate": 1.0
    },
    {
      "id": "assay_type_non_empty",
      "type": "non_empty_rate",
      "column": "assay_type",
      "min_rate": 1.0
    },
    {
      "id": "standard_type_allowed",
      "type": "allowed_values_rate",
      "column": "standard_type",
      "allowed": ["IC50", "Ki", "Kd", "EC50"],
      "min_rate": 1.0
    },
    {
      "id": "standard_value_numeric",
      "type": "regex_rate",
      "column": "standard_value",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$",
      "min_rate": 1.0
    },
    {
      "id": "standard_unit_non_empty",
      "type": "non_empty_rate",
      "column": "standard_unit",
      "min_rate": 1.0
    },
    {
      "id": "normalized_nM_numeric",
      "type": "regex_rate",
      "column": "normalized_nM",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$",
      "min_rate": 1.0
    },
    {
      "id": "confidence_allowed",
      "type": "allowed_values_rate",
      "column": "confidence",
      "allowed": ["high", "medium", "low"],
      "min_rate": 1.0
    },
    {
      "id": "confidence_score_numeric",
      "type": "regex_rate",
      "column": "confidence_score",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "min_rate": 1.0
    },
    {
      "id": "source_version_non_empty",
      "type": "non_empty_rate",
      "column": "source_version",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_format",
      "type": "regex_rate",
      "column": "fetch_date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "min_rate": 1.0
    }
  ]
}
