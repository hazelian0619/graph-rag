{
  "name": "edges_ppi_v1",
  "required_columns": [
    "edge_id",
    "src_type",
    "src_id",
    "dst_type",
    "dst_id",
    "predicate",
    "directed",
    "best_score",
    "source",
    "source_version",
    "fetch_date"
  ],
  "rules": [
    {
      "id": "edge_id_non_empty",
      "type": "non_empty_rate",
      "column": "edge_id",
      "min_rate": 1.0
    },
    {
      "id": "edge_id_unique",
      "type": "unique",
      "column": "edge_id"
    },
    {
      "id": "src_type_protein",
      "type": "equals_value_rate",
      "column": "src_type",
      "value": "Protein",
      "min_rate": 1.0
    },
    {
      "id": "dst_type_protein",
      "type": "equals_value_rate",
      "column": "dst_type",
      "value": "Protein",
      "min_rate": 1.0
    },
    {
      "id": "predicate_non_empty",
      "type": "non_empty_rate",
      "column": "predicate",
      "min_rate": 1.0
    },
    {
      "id": "directed_bool",
      "type": "regex_rate",
      "column": "directed",
      "pattern": "^(true|false)$",
      "min_rate": 1.0
    },
    {
      "id": "source_non_empty",
      "type": "non_empty_rate",
      "column": "source",
      "min_rate": 1.0
    },
    {
      "id": "source_version_non_empty",
      "type": "non_empty_rate",
      "column": "source_version",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_iso",
      "type": "regex_rate",
      "column": "fetch_date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "min_rate": 1.0
    }
  ]
}
