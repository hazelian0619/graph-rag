{
  "name": "psi_activity_context_v2",
  "description": "PSI per-edge activity + assay context (relation symbols, assay semantics, condition extraction)",
  "required_columns": [
    "edge_id",
    "activity_id",
    "assay_id",
    "doc_id",
    "compound_inchikey",
    "target_uniprot_accession",
    "target_chembl_id",
    "standard_type",
    "standard_relation",
    "standard_relation_raw",
    "standard_value",
    "standard_units",
    "standard_value_nM",
    "pchembl_value",
    "pchembl_value_eff",
    "assay_type",
    "assay_type_desc",
    "assay_description",
    "assay_context",
    "assay_confidence_score",
    "bao_format",
    "condition_pH",
    "condition_temperature_c",
    "condition_system",
    "condition_context",
    "data_validity_comment",
    "activity_comment",
    "doi",
    "pubmed_id",
    "n_evidence",
    "n_docs",
    "evidence_score_max",
    "source",
    "source_version",
    "fetch_date"
  ],
  "rules": [
    {
      "id": "edge_id_non_empty",
      "type": "non_empty_rate",
      "column": "edge_id",
      "min_rate": 1.0
    },
    {
      "id": "edge_id_unique",
      "type": "unique",
      "column": "edge_id"
    },
    {
      "id": "standard_type_non_empty",
      "type": "non_empty_rate",
      "column": "standard_type",
      "min_rate": 0.95
    },
    {
      "id": "standard_relation_allowed",
      "type": "allowed_values_rate",
      "column": "standard_relation",
      "allowed": ["=", "<", ">", "<=", ">=", "~"],
      "min_rate": 0.99
    },
    {
      "id": "assay_type_enum",
      "type": "allowed_values_rate",
      "column": "assay_type",
      "allowed": ["B", "F", "A", "T", "P", "UNK"],
      "min_rate": 1.0
    },
    {
      "id": "assay_context_non_empty",
      "type": "non_empty_rate",
      "column": "assay_context",
      "min_rate": 0.90
    },
    {
      "id": "source_version_non_empty",
      "type": "non_empty_rate",
      "column": "source_version",
      "min_rate": 1.0
    },
    {
      "id": "fetch_date_format",
      "type": "regex_rate",
      "column": "fetch_date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "min_rate": 1.0
    }
  ]
}
